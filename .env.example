# OpenAI-compatible LLM provider configuration.
# Copy this file to `.env` and fill exactly one provider block before running the LLM agent.
# Never commit `.env` or real API keys.

# Generic template policy: optimization/policy_versions/llm_openai_compatible_template.json
# LLM_API_KEY=
# LLM_BASE_URL=https://replace-with-provider-base-url
# LLM_MODEL=replace-with-model-name

# DeepSeek policy: optimization/policy_versions/llm_deepseek_minimal.json
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Kimi / Moonshot policy: optimization/policy_versions/llm_kimi_minimal.json
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2-0711-preview

# GLM / Zhipu policy: optimization/policy_versions/llm_glm_minimal.json
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4.5
