{
  "policy_id": "llm_ollama_qwen_coder7b_local",
  "description": "本地 Ollama Qwen2.5 Coder 7B 策略，面向 CPU-only 小样本 A/B，限制输出长度并关闭 SDK 自动重试。",
  "max_steps": 12,
  "max_retries": 1,
  "max_patch_files": 1,
  "agent_type": "llm",
  "patch_strategy": "baseline",
  "llm_provider": "openai_compatible",
  "llm_model": "qwen2.5-coder:7b-instruct-q4_k_m",
  "llm_api_key_env": "DEEPSEEK_API_KEY",
  "llm_base_url_env": "DEEPSEEK_BASE_URL",
  "llm_model_env": "DEEPSEEK_MODEL",
  "llm_base_url": "http://127.0.0.1:11434/v1",
  "llm_max_output_tokens": 1200,
  "llm_timeout_sec": 180,
  "llm_client_max_retries": 0,
  "pytest_additional_flags": [
    "-p no:unraisableexception",
    "-p no:threadexception"
  ]
}
