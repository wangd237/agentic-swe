{
  "policy_id": "llm_deepseek_minimal",
  "description": "最小 OpenAI-compatible coding agent 策略，当前使用 DeepSeek 配置，复用现有工具与 harness。",
  "max_steps": 16,
  "max_retries": 2,
  "max_patch_files": 1,
  "agent_type": "llm",
  "patch_strategy": "baseline",
  "llm_provider": "openai_compatible",
  "llm_model": "deepseek-chat",
  "llm_api_key_env": "DEEPSEEK_API_KEY",
  "llm_base_url_env": "DEEPSEEK_BASE_URL",
  "llm_model_env": "DEEPSEEK_MODEL",
  "llm_base_url": "https://api.deepseek.com",
  "llm_max_output_tokens": 8000,
  "llm_timeout_sec": 180,
  "pytest_additional_flags": [
    "-p no:unraisableexception",
    "-p no:threadexception"
  ],
  "code_intelligence_backend": "codebase_memory_cli",
  "codebase_memory_binary": ".tools/codebase-memory-mcp/codebase-memory-mcp.exe",
  "codebase_memory_index_mode": "fast",
  "codebase_memory_always_shadow_copy": true,
  "code_intelligence_timeout_sec": 30.0,
  "code_intelligence_max_results": 5
}
