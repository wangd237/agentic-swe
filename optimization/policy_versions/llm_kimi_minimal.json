{
  "policy_id": "llm_kimi_minimal",
  "description": "最小 OpenAI-compatible coding agent 策略示例，使用 Kimi / Moonshot 配置。",
  "max_steps": 16,
  "max_retries": 2,
  "max_patch_files": 1,
  "agent_type": "llm",
  "patch_strategy": "baseline",
  "llm_provider": "openai_compatible",
  "llm_model": "kimi-k2-0711-preview",
  "llm_api_key_env": "KIMI_API_KEY",
  "llm_base_url_env": "KIMI_BASE_URL",
  "llm_model_env": "KIMI_MODEL",
  "llm_base_url": "https://api.moonshot.cn/v1",
  "llm_max_output_tokens": 8000,
  "pytest_additional_flags": [
    "-p no:unraisableexception",
    "-p no:threadexception"
  ]
}
